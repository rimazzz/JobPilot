# ---------------------------------------------------------------------------
# JobPilot configuration. Copy to `.env` and fill in the values you need.
# All variables are prefixed with JOBPILOT_ and are optional unless noted.
# ---------------------------------------------------------------------------

# --- LLM provider -----------------------------------------------------------
# Which chat-model back-end to use: "anthropic" (default) or "openai".
JOBPILOT_LLM_PROVIDER=anthropic

# Model id for the selected provider. Defaults to Claude Opus 4.8.
JOBPILOT_LLM_MODEL=claude-opus-4-8

# Max output tokens per LLM call.
JOBPILOT_LLM_MAX_TOKENS=4096

# Sampling temperature. Leave unset for models that reject it (e.g. Opus 4.8).
# JOBPILOT_LLM_TEMPERATURE=0.2

# Custom OpenAI-compatible endpoint (used only when provider=openai). This lets
# you point at OpenRouter, DeepSeek, Together, Groq, a local server, etc.
# Example — DeepSeek via OpenRouter:
#   JOBPILOT_LLM_PROVIDER=openai
#   JOBPILOT_LLM_MODEL=deepseek/deepseek-chat
#   JOBPILOT_LLM_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=sk-or-v1-...
# JOBPILOT_LLM_BASE_URL=

# Provider API keys. Only the key for the selected provider is required to run
# against a live model; tests and dry runs do not need one.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Job search -------------------------------------------------------------
# Search provider: "sample" (offline fixtures, default) or "remote" (HTTP API).
JOBPILOT_SEARCH_PROVIDER=sample
# Base URL + key for a remote job board when JOBPILOT_SEARCH_PROVIDER=remote.
# JOBPILOT_SEARCH_API_URL=https://api.example-jobs.com/v1/search
# JOBPILOT_SEARCH_API_KEY=

# --- Browser automation -----------------------------------------------------
# How the Application agent interacts with forms:
#   auto       -> Playwright for live http(s) forms, simulated otherwise (default)
#   playwright -> always drive a real Chromium browser
#   simulated  -> never launch a browser; fabricate a standard form offline
JOBPILOT_BROWSER_MODE=auto
# Run the browser headless (recommended for servers/containers).
JOBPILOT_BROWSER_HEADLESS=true
# Never submit forms automatically. Submission always requires explicit human
# approval; this flag is a second safety net and should stay true in most cases.
JOBPILOT_BROWSER_ALLOW_SUBMIT=true
# Directory where screenshots and form previews are written.
JOBPILOT_ARTIFACTS_DIR=artifacts

# --- Runtime ----------------------------------------------------------------
# Logging level and format ("json" for production, "console" for local dev).
JOBPILOT_LOG_LEVEL=INFO
JOBPILOT_LOG_FORMAT=console
# SQLite file used to checkpoint LangGraph runs (enables pause/resume).
JOBPILOT_CHECKPOINT_DB=checkpoints.sqlite
